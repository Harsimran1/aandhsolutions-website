---
import { resolveLocale } from '../lib/i18n';
import { CLIENT_LOGOS } from '../data/client-logos';

const locale = resolveLocale(Astro.currentLocale, new URL(Astro.request.url).pathname);

const copyByLocale = {
  en: {
    badge: 'Client Portfolio',
    title: "Clients We've Worked With",
    description: 'Selected logos from products and teams we have delivered software for.',
  },
  de: {
    badge: 'Kundenportfolio',
    title: 'Kunden, mit denen wir gearbeitet haben',
    description: 'Ausgewahlte Logos von Produkten und Teams, fur die wir Software entwickelt haben.',
  },
  fr: {
    badge: 'Portfolio clients',
    title: 'Clients avec lesquels nous avons travaille',
    description: 'Logos selectionnes de produits et d equipes pour lesquels nous avons livre des logiciels.',
  },
  es: {
    badge: 'Portafolio de clientes',
    title: 'Clientes con los que hemos trabajado',
    description: 'Logotipos seleccionados de productos y equipos para los que hemos entregado software.',
  },
} as const;

const text = copyByLocale[locale] ?? copyByLocale.en;
const marqueeLogos = [...CLIENT_LOGOS, ...CLIENT_LOGOS];
---

<section class="section bg-gray-50 dark:bg-gray-900/40" aria-label={text.title}>
  <div class="container-custom">
    <div class="text-center max-w-3xl mx-auto mb-10">
      <span class="inline-block px-4 py-1 rounded-full bg-secondary-100 dark:bg-secondary-900 text-secondary-600 dark:text-secondary-300 font-medium text-sm mb-4">
        {text.badge}
      </span>
      <h2 class="mb-4 text-gray-900 dark:text-white">{text.title}</h2>
      <p class="text-gray-600 dark:text-gray-300">{text.description}</p>
    </div>

    <div class="client-logo-marquee" role="region" aria-label={text.title}>
      <div class="client-logo-track">
        {marqueeLogos.map((client, index) => (
          <a
            href={client.url}
            target="_blank"
            rel="noopener noreferrer"
            class="client-logo-card"
            aria-label={`Visit ${client.name}`}
            aria-hidden={index >= CLIENT_LOGOS.length ? 'true' : undefined}
            tabindex={index >= CLIENT_LOGOS.length ? -1 : undefined}
          >
            <img
              src={client.logoPath}
              alt={client.alt ?? `${client.name} logo`}
              class="client-logo-image"
              loading="lazy"
              decoding="async"
            />
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .client-logo-marquee {
    position: relative;
    overflow: hidden;
  }

  .client-logo-track {
    display: flex;
    gap: 1rem;
    width: max-content;
    animation: clientLogoScroll 30s linear infinite;
    will-change: transform;
  }

  .client-logo-marquee:hover .client-logo-track,
  .client-logo-marquee:focus-within .client-logo-track {
    animation-play-state: paused;
  }

  .client-logo-card {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 112px;
    min-width: clamp(11rem, 19vw, 14.5rem);
    padding: 1.1rem;
    border: 1px solid rgb(226 232 240 / 1);
    border-radius: 0.9rem;
    background: white;
    transition: border-color 180ms ease, transform 180ms ease, box-shadow 180ms ease;
  }

  .dark .client-logo-card {
    border-color: rgb(51 65 85 / 1);
    background: rgb(15 23 42 / 1);
  }

  .client-logo-card:hover {
    border-color: rgb(124 58 237 / 0.5);
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgb(2 6 23 / 0.08);
  }

  .dark .client-logo-card:hover {
    box-shadow: 0 10px 25px rgb(2 6 23 / 0.35);
  }

  .client-logo-image {
    width: 100%;
    max-width: 176px;
    max-height: 58px;
    object-fit: contain;
    filter: saturate(0.95);
  }

  .dark .client-logo-image {
    filter: brightness(0.92) contrast(1.05);
  }

  @keyframes clientLogoScroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .client-logo-marquee {
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
    }

    .client-logo-track {
      animation: none;
      padding-bottom: 0.25rem;
    }

    .client-logo-card {
      scroll-snap-align: start;
    }
  }
</style>
