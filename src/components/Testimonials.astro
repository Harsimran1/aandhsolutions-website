---
import { resolveLocale, localizePath } from '../lib/i18n';
import { CLUTCH_REVIEWS, REVIEW_COPY, type LocaleKey } from '../data/reviews';
import ReviewCarousel from './ReviewCarousel.astro';

const locale = resolveLocale(Astro.currentLocale, new URL(Astro.request.url).pathname);
const localized = (path: string) => localizePath(path, locale);
const text = REVIEW_COPY[locale as LocaleKey] ?? REVIEW_COPY.en;

const totalReviews = CLUTCH_REVIEWS.length || 1;
const averageRating = (CLUTCH_REVIEWS.reduce((sum, review) => sum + review.rating.overall, 0) / totalReviews).toFixed(1);
const averageRefer = (CLUTCH_REVIEWS.reduce((sum, review) => sum + review.rating.willingToRefer, 0) / totalReviews).toFixed(1);
---

<section id="testimonials" class="section">
  <div class="container-custom">
    <div class="text-center max-w-3xl mx-auto mb-10">
      <span class="inline-block px-4 py-1 rounded-full bg-secondary-100 dark:bg-secondary-900 text-secondary-600 dark:text-secondary-300 font-medium text-sm mb-4">
        {text.badge}
      </span>
      <h2 class="mb-6 text-gray-900 dark:text-white">{text.title}</h2>
      <p class="text-gray-600 dark:text-gray-300">{text.description}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-12">
      <div class="card p-4 text-center border border-gray-200 dark:border-gray-700 min-h-[120px] flex flex-col items-center justify-center">
        <p class="text-3xl font-bold text-primary-600 dark:text-primary-400">{averageRating}</p>
        <p class="text-sm text-gray-600 dark:text-gray-300">{text.proofStrip.ratingLabel}</p>
      </div>
      <div class="card p-4 text-center border border-gray-200 dark:border-gray-700 min-h-[120px] flex flex-col items-center justify-center">
        <p class="text-3xl font-bold text-primary-600 dark:text-primary-400">100%</p>
        <p class="text-sm text-gray-600 dark:text-gray-300">{text.proofStrip.verifiedLabel}</p>
      </div>
      <div class="card p-4 text-center border border-gray-200 dark:border-gray-700 min-h-[120px] flex flex-col items-center justify-center">
        <p class="text-3xl font-bold text-primary-600 dark:text-primary-400">{averageRefer}</p>
        <p class="text-sm text-gray-600 dark:text-gray-300">{text.proofStrip.referLabel}</p>
      </div>
    </div>

    <ReviewCarousel reviews={CLUTCH_REVIEWS} cardCopy={text.card} ariaLabel={text.title} />

    <div class="mt-16 bg-linear-to-r from-primary-500 to-secondary-500 rounded-2xl p-8 md:p-12 relative overflow-hidden">
      <div class="absolute inset-0 bg-linear-to-r from-primary-600/30 to-secondary-600/30 backdrop-blur-xs"></div>
      <div class="relative z-10 text-center md:text-left md:flex items-center justify-between">
        <div class="mb-6 md:mb-0 md:mr-8">
          <h3 class="text-2xl md:text-3xl font-bold text-white mb-4">{text.cta.title}</h3>
          <p class="text-white/80 max-w-2xl">{text.cta.description}</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href={localized('/contact')} class="inline-flex items-center justify-center px-6 py-3 rounded-lg font-medium transition-all duration-300 bg-white text-primary-600 hover:bg-gray-100">
            {text.cta.primary}
          </a>
          <a href={localized('/case-studies')} class="inline-flex items-center justify-center px-6 py-3 rounded-lg font-medium transition-all duration-300 border border-white text-white hover:bg-white/10">
            {text.cta.secondary}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
