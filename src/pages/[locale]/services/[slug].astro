---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { SUPPORTED_LOCALES, resolveLocale, localizePath } from '../../../lib/i18n';
import { getLocaleCopy } from '../../../i18n/locale-copy';
import { CLUTCH_REVIEWS } from '../../../data/reviews';

export const prerender = true;

export async function getStaticPaths() {
  const services = await getCollection('services', ({ data }) => !data.draft);
  return SUPPORTED_LOCALES.flatMap((locale) =>
    services.map((service) => ({
      params: { locale, slug: service.slug },
      props: { service },
    })),
  );
}

const { service } = Astro.props;
const { Content } = await service.render();
const locale = resolveLocale(Astro.currentLocale, new URL(Astro.request.url).pathname);
const localized = (path: string) => localizePath(path, locale);
const copy = getLocaleCopy(locale);
const servicesContent = copy.content?.services ?? {};
const domainContent = copy.content?.domains ?? {};
const serviceCopy = servicesContent[service.slug] ?? {};
const localizedTitle = serviceCopy.title || service.data.title;
const localizedDescription = serviceCopy.description || serviceCopy.excerpt || service.data.description || service.data.excerpt || service.data.title;
const localizedExcerpt = serviceCopy.excerpt || service.data.excerpt;
const localizedCategory = serviceCopy.category || service.data.category;
const localizedBodyHtml = serviceCopy.bodyHtml || null;
const localizedDeliverables = serviceCopy.deliverables ?? service.data.deliverables;
const localizedProcessSteps = serviceCopy.processSteps ?? service.data.processSteps;
const localizedPricingModel = serviceCopy.pricingModel || service.data.pricing?.model;
const localizedRelatedDomains = serviceCopy.relatedDomains ?? service.data.relatedDomains ?? [];

const allCaseStudies = await getCollection('case-studies', ({ data }) => !data.draft);
const relatedCaseStudies = allCaseStudies.filter((cs) =>
  cs.data.relatedServices?.includes(service.slug)
);

const allDomains = await getCollection('domains', ({ data }) => !data.draft);
const normalizedDomainSlug = new Map<string, string>();
const normalize = (value: string) => value.toLowerCase().trim();

for (const domain of allDomains) {
  normalizedDomainSlug.set(normalize(domain.data.industry), domain.slug);
  normalizedDomainSlug.set(normalize(domain.data.title), domain.slug);
}

const relatedDomainLinks = localizedRelatedDomains.map((domainName: string) => {
  const slug = normalizedDomainSlug.get(normalize(domainName));
  const fallbackSlug = domainName.toLowerCase().replace(/\s+/g, '-');
  const domainSlug = slug || fallbackSlug;
  const translatedDomain = domainContent[domainSlug] ?? {};
  const label = translatedDomain.industry || translatedDomain.title || domainName;

  return {
    href: localized(`/domains/${domainSlug}`),
    label,
  };
});

const ui = {
  en: { back: 'Back to Services', expert: 'Service Expert', details: 'Service Details', technologies: 'Technologies', whatYouGet: 'What You Get', pricing: 'Pricing', getStarted: 'Get Started', viewExamples: 'View Examples', process: 'Our Process', related: 'Related Industries' },
  de: { back: 'Zuruck zu Leistungen', expert: 'Service-Experte', details: 'Leistungsdetails', technologies: 'Technologien', whatYouGet: 'Leistungsumfang', pricing: 'Preise', getStarted: 'Jetzt starten', viewExamples: 'Beispiele ansehen', process: 'Unser Prozess', related: 'Verwandte Branchen' },
  fr: { back: 'Retour aux services', expert: 'Expert service', details: 'Details du service', technologies: 'Technologies', whatYouGet: 'Ce que vous obtenez', pricing: 'Tarification', getStarted: 'Demarrer', viewExamples: 'Voir des exemples', process: 'Notre methode', related: 'Secteurs associes' },
  es: { back: 'Volver a servicios', expert: 'Experto de servicio', details: 'Detalles del servicio', technologies: 'Tecnologias', whatYouGet: 'Que obtienes', pricing: 'Precios', getStarted: 'Comenzar', viewExamples: 'Ver ejemplos', process: 'Nuestro proceso', related: 'Industrias relacionadas' },
} as const;
const text = ui[locale] ?? ui.en;
---

<Layout title={`${localizedTitle} - A & H Solutions Services`} description={localizedDescription}>
  <Header />
  <main>
    <article class="pt-32 pb-16 md:pt-40 md:pb-24">
      <div class="container-custom max-w-4xl">
        <div class="mb-8">
          <a href={localized('/services')} class="inline-flex items-center text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
            </svg>
            {text.back}
          </a>
        </div>

        <div class="flex items-center mb-6">
          {localizedCategory && (
            <>
              <span class="inline-block px-3 py-1 rounded-full bg-primary-100 dark:bg-primary-900 text-primary-600 dark:text-primary-300 font-medium text-sm">{localizedCategory}</span>
              <span class="mx-2 text-gray-300 dark:text-gray-600">•</span>
            </>
          )}
          {service.data.pricing && service.data.pricing.startingPrice && (
            <span class="text-gray-600 dark:text-gray-400">{service.data.pricing.startingPrice}</span>
          )}
        </div>

        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6 text-gray-900 dark:text-white">{localizedTitle}</h1>

        {localizedExcerpt && <p class="text-xl text-gray-600 dark:text-gray-300 mb-8">{localizedExcerpt}</p>}

        <div class="flex items-center mb-8">
          {service.data.author.avatar && <img src={service.data.author.avatar} alt={service.data.author.name} class="w-12 h-12 rounded-full mr-4 object-cover" />}
          <div>
            <p class="font-semibold text-gray-900 dark:text-white">{service.data.author.name}</p>
            <p class="text-gray-600 dark:text-gray-400">{text.expert}</p>
          </div>
        </div>

        {service.data.image && <img src={service.data.image} alt={service.data.imageAlt || localizedTitle} class="w-full h-auto rounded-xl mb-10 object-cover" style="max-height: 500px;" />}

        <div class="grid md:grid-cols-3 gap-8 mb-12">
          <div class="md:col-span-2">
            <div class="prose prose-lg dark:prose-invert max-w-none">
              {localizedBodyHtml ? (
                <Fragment set:html={localizedBodyHtml} />
              ) : (
                <Content />
              )}
            </div>
          </div>

          <div class="bg-gray-50 dark:bg-gray-800 p-6 rounded-xl">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">{text.details}</h3>

            {service.data.technologies && service.data.technologies.length > 0 && (
              <div class="mb-6">
                <h4 class="font-medium text-gray-900 dark:text-white mb-3">{text.technologies}</h4>
                <div class="flex flex-wrap gap-2">
                  {service.data.technologies.map((tech) => (
                    <span class="px-3 py-1 bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-300 text-sm rounded-full border border-gray-200 dark:border-gray-600">{tech}</span>
                  ))}
                </div>
              </div>
            )}

            {localizedDeliverables && localizedDeliverables.length > 0 && (
              <div class="mb-6">
                <h4 class="font-medium text-gray-900 dark:text-white mb-3">{text.whatYouGet}</h4>
                <ul class="space-y-2">
                  {localizedDeliverables.map((deliverable: string) => (
                    <li class="flex items-center text-sm text-gray-600 dark:text-gray-300">
                      <svg class="w-4 h-4 text-green-500 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                      </svg>
                      {deliverable}
                    </li>
                  ))}
                </ul>
              </div>
            )}

            {service.data.pricing && (
              <div class="mb-6">
                <h4 class="font-medium text-gray-900 dark:text-white mb-3">{text.pricing}</h4>
                {service.data.pricing.startingPrice && <p class="text-2xl font-bold text-primary-600 dark:text-primary-400 mb-2">{service.data.pricing.startingPrice}</p>}
                {localizedPricingModel && <p class="text-sm text-gray-600 dark:text-gray-300 mb-3">{localizedPricingModel}</p>}
              </div>
            )}

            <div class="pt-4 border-t border-gray-200 dark:border-gray-700">
              <a href={localized('/contact')} class="btn-primary w-full text-center">{text.getStarted}</a>
              <a href={localized('/case-studies')} class="btn-outline w-full text-center mt-3">{text.viewExamples}</a>
            </div>
          </div>
        </div>

        {localizedProcessSteps && localizedProcessSteps.length > 0 && (
          <div class="mb-12">
            <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-8 text-center">{text.process}</h3>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
              {localizedProcessSteps.map((step: { title: string; description: string }, index: number) => (
                <div class="text-center">
                  <div class="w-12 h-12 bg-primary-600 text-white rounded-full flex items-center justify-center text-xl font-bold mx-auto mb-4">{index + 1}</div>
                  <h4 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">{step.title}</h4>
                  <p class="text-gray-600 dark:text-gray-300">{step.description}</p>
                </div>
              ))}
            </div>
          </div>
        )}

        {relatedDomainLinks.length > 0 && (
          <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-700">
            <h3 class="text-xl font-semibold mb-6 text-gray-900 dark:text-white">{text.related}</h3>
            <div class="flex flex-wrap gap-2">
              {relatedDomainLinks.map((domain) => (
                <a href={domain.href} class="px-4 py-2 bg-secondary-100 dark:bg-secondary-900 text-secondary-700 dark:text-secondary-300 rounded-full hover:bg-secondary-200 dark:hover:bg-secondary-800 transition-colors">
                  {domain.label}
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </article>
    {relatedCaseStudies.length > 0 && (
      <section class="py-16 bg-gray-50 dark:bg-gray-900 border-t border-gray-200 dark:border-gray-700">
        <div class="container-custom">
          <div class="text-center mb-10">
            <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-3">Work That Proves It</h2>
            <p class="text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">Real projects delivered using {localizedTitle}.</p>
          </div>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {relatedCaseStudies.map((cs) => {
              const topMetric = cs.data.results?.metrics?.[0];
              const hasImage = cs.data.image && !cs.data.image.includes('no-image-available');
              const heroImage = hasImage
                ? (cs.data.gallery && cs.data.gallery.length > 0 ? cs.data.gallery[0] : cs.data.image)
                : null;
              return (
                <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 flex flex-col hover:shadow-md transition-shadow overflow-hidden">
                  {heroImage && (
                    <div class="h-40 overflow-hidden bg-gray-100 dark:bg-gray-700">
                      <img
                        src={heroImage}
                        alt={cs.data.imageAlt || cs.data.title}
                        class="w-full h-full object-cover"
                        loading="lazy"
                      />
                    </div>
                  )}
                  <div class="p-6 flex flex-col flex-1">
                    <div class="flex flex-wrap items-center gap-2 mb-3">
                      {cs.data.client && (
                        <span class="px-2 py-0.5 rounded-full bg-secondary-100 dark:bg-secondary-900 text-secondary-600 dark:text-secondary-300 text-xs font-medium">
                          {cs.data.client.industry}
                        </span>
                      )}
                      {cs.data.tags.slice(0, 2).map((tag) => (
                        <span class="px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400 text-xs">
                          {tag}
                        </span>
                      ))}
                    </div>
                    <h3 class="text-base font-semibold text-gray-900 dark:text-white mb-2">{cs.data.title}</h3>
                    {(cs.data.excerpt || cs.data.description) && (
                      <p class="text-sm text-gray-600 dark:text-gray-300 mb-4 flex-1 line-clamp-2">{cs.data.excerpt || cs.data.description}</p>
                    )}
                    {topMetric && (
                      <div class="bg-primary-50 dark:bg-primary-900/20 rounded-lg p-3 mb-4">
                        <p class="text-xl font-bold text-primary-600 dark:text-primary-400 leading-tight">{topMetric.value}</p>
                        <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">{topMetric.label}</p>
                      </div>
                    )}
                    <a href={localized(`/case-studies/${cs.slug}`)} class="btn-outline btn-sm w-full text-center mt-auto">
                      Read Case Study
                    </a>
                  </div>
                </div>
              );
            })}
          </div>
          <div class="text-center mt-10">
            <a href={localized('/case-studies')} class="btn-outline">View All Case Studies</a>
          </div>
        </div>
      </section>
    )}

    {CLUTCH_REVIEWS.length > 0 && (
      <section class="py-16 bg-white dark:bg-gray-800 border-t border-gray-200 dark:border-gray-700">
        <div class="container-custom">
          <div class="text-center mb-10">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-orange-50 dark:bg-orange-900/20 border border-orange-200 dark:border-orange-800 rounded-full mb-4">
              <span class="text-yellow-500 text-sm">★★★★★</span>
              <span class="text-orange-600 dark:text-orange-400 text-sm font-medium">Verified on Clutch</span>
            </div>
            <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-3">What Clients Say</h2>
            <p class="text-gray-600 dark:text-gray-300">Every review is verified and published on Clutch.</p>
          </div>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {CLUTCH_REVIEWS.slice(0, 3).map((review) => (
              <div class="bg-gray-50 dark:bg-gray-900 rounded-xl p-6 border border-gray-200 dark:border-gray-700 flex flex-col">
                <div class="text-yellow-400 text-lg mb-3">★★★★★</div>
                <blockquote class="text-gray-700 dark:text-gray-300 text-sm italic leading-relaxed mb-4 flex-1">
                  "{review.quote}"
                </blockquote>
                <div class="border-t border-gray-200 dark:border-gray-700 pt-4">
                  <p class="font-semibold text-gray-900 dark:text-white text-sm">
                    {review.reviewer === 'Anonymous' ? review.reviewerRole : review.reviewer}
                  </p>
                  <p class="text-xs text-gray-500 dark:text-gray-400">{review.reviewerRole}, {review.company}</p>
                  <p class="text-xs text-gray-400 dark:text-gray-500 mt-0.5">{review.industry} · {review.location}</p>
                  <a
                    href={review.clutchUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1 text-xs text-orange-600 dark:text-orange-400 hover:underline mt-3 font-medium"
                  >
                    Read full review on Clutch
                    <svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor">
                      <path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z"/>
                      <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z"/>
                    </svg>
                  </a>
                </div>
              </div>
            ))}
          </div>
          <div class="text-center mt-10">
            <a href={localized('/reviews')} class="btn-outline">See All Reviews</a>
          </div>
        </div>
      </section>
    )}
  </main>
  <Footer />
</Layout>
