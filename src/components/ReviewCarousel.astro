---
import type { ClutchReviewRecord } from '../data/reviews';

interface CardCopy {
  serviceLabel: string;
  periodLabel: string;
  locationLabel: string;
  readOnClutch: string;
}

interface Props {
  reviews: ClutchReviewRecord[];
  cardCopy: CardCopy;
  showDetails?: boolean;
  ariaLabel?: string;
}

const {
  reviews,
  cardCopy,
  showDetails = false,
  ariaLabel = 'Client reviews carousel',
} = Astro.props;

const marqueeReviews = [...reviews, ...reviews];
---

<div class="review-marquee" role="region" aria-label={ariaLabel}>
  <div class="review-marquee__track">
    {marqueeReviews.map((review, index) => (
      <article class="review-marquee__item card p-6 border border-gray-200 dark:border-gray-700" aria-hidden={index >= reviews.length ? 'true' : undefined}>
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center gap-1 text-warning-400">
            {[...Array(5)].map(() => (
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
              </svg>
            ))}
          </div>
          <p class="text-xs text-gray-500 dark:text-gray-400">{review.date}</p>
        </div>

        <blockquote class="mb-4 text-gray-700 dark:text-gray-300 italic">"{review.quote}"</blockquote>

        <div class="mb-4">
          <p class="font-semibold text-gray-900 dark:text-white">{review.reviewerRole}, {review.company}</p>
          <p class="text-sm text-gray-500 dark:text-gray-400">{review.location}</p>
        </div>

        {showDetails && (
          <div class="space-y-1 mb-5 text-sm text-gray-600 dark:text-gray-300">
            <p><span class="font-medium">{cardCopy.serviceLabel}:</span> {review.services}</p>
            <p><span class="font-medium">{cardCopy.periodLabel}:</span> {review.projectPeriod}</p>
            <p><span class="font-medium">{cardCopy.locationLabel}:</span> {review.location}</p>
          </div>
        )}

        <a
          href={review.clutchUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300 font-medium text-sm"
          tabindex={index >= reviews.length ? -1 : undefined}
        >
          {cardCopy.readOnClutch}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </a>
      </article>
    ))}
  </div>
</div>
